{
  "openapi": "3.0.3",
  "info": {
    "title": "GetDocumented Screenshots API",
    "version": "1.0.0",
    "description": "OpenAPI spec for managing walkthrough screenshots and exporting them as PDF."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Health"
    },
    {
      "name": "Screenshots"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/screenshots": {
      "get": {
        "tags": [
          "Screenshots"
        ],
        "summary": "List screenshots",
        "responses": {
          "200": {
            "description": "Screenshots returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Screenshot"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Screenshots"
        ],
        "summary": "Create a screenshot",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/CreateScreenshotRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Screenshot created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Screenshot"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "Uploaded file too large",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/screenshots/{id}": {
      "patch": {
        "tags": [
          "Screenshots"
        ],
        "summary": "Update a screenshot",
        "parameters": [
          {
            "$ref": "#/components/parameters/ScreenshotId"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateScreenshotRequest"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UpdateScreenshotRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Screenshot updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Screenshot"
                }
              }
            }
          },
          "404": {
            "description": "Screenshot not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Screenshots"
        ],
        "summary": "Delete a screenshot",
        "parameters": [
          {
            "$ref": "#/components/parameters/ScreenshotId"
          }
        ],
        "responses": {
          "204": {
            "description": "Screenshot deleted"
          },
          "404": {
            "description": "Screenshot not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/screenshots/{id}/image": {
      "get": {
        "tags": [
          "Screenshots"
        ],
        "summary": "Get screenshot image binary",
        "parameters": [
          {
            "$ref": "#/components/parameters/ScreenshotId"
          }
        ],
        "responses": {
          "200": {
            "description": "Image binary",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "Screenshot not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/screenshots/export/pdf": {
      "get": {
        "tags": [
          "Screenshots"
        ],
        "summary": "Export all screenshots as PDF",
        "responses": {
          "200": {
            "description": "PDF document",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "ScreenshotId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Screenshot identifier"
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          }
        },
        "required": [
          "status"
        ]
      },
      "Screenshot": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "mimeType": {
            "type": "string"
          },
          "fileName": {
            "type": "string"
          },
          "position": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "imageUrl": {
            "type": "string",
            "example": "/api/screenshots/<id>/image"
          }
        },
        "required": [
          "id",
          "title",
          "description",
          "mimeType",
          "position",
          "createdAt",
          "updatedAt",
          "imageUrl"
        ]
      },
      "CreateScreenshotRequest": {
        "type": "object",
        "required": [
          "title",
          "description",
          "image"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "position": {
            "type": "integer",
            "default": 0
          },
          "image": {
            "type": "string",
            "format": "binary"
          }
        }
      },
      "UpdateScreenshotRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "position": {
            "type": "integer"
          },
          "image": {
            "type": "string",
            "format": "binary"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "required": [
          "message"
        ]
      }
    }
  }
}
